.git/
.github/
.gitignore
.vscode/
.idea/
.env
.env.local

# Documentation
*.md

# Build artifacts
build/
dist/

# Test files
test*.py
*_test.py

# Config files not needed
railway.toml
railway.json
render.yaml
nixpacks.toml
Procfile

# Scripts (except backend/app/start.sh)
build.sh
test-docker-build.ps1

# Misc
.DS_Store
*.log
Thumbs.db
