# Python cache
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
.pytest_cache/

# Model files (downloaded at runtime)
backend/app/saved_models/*.pth
*.pth

# Data files (not needed in production)
backend/app/data/raw/
backend/app/data/processed/
backend/app/output/
*.mat
*.h5
*.hdf5

# Development
.git/
.github/
.gitignore
.vscode/
.idea/
.env
.env.local

# Documentation
*.md
!backend/app/*.md

# Build artifacts
build/
dist/

# Test files
test_*.py
*_test.py
backend/app/test_*.py
backend/app/*_test.py

# Config files not needed
railway.json
render.yaml
nixpacks.toml

# Misc
.DS_Store
*.log
Thumbs.db
